{
  "name": "@zauso-ai/capstan-cli",
  "version": "0.3.1",
  "type": "module",
  "bin": {
    "capstan": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@zauso-ai/capstan-ai": "0.3.1",
    "@zauso-ai/capstan-agent": "0.3.1",
    "@zauso-ai/capstan-auth": "0.3.1",
    "@zauso-ai/capstan-core": "0.3.1",
    "@zauso-ai/capstan-db": "0.3.1",
    "@zauso-ai/capstan-dev": "0.3.1",
    "@zauso-ai/capstan-ops": "0.3.1",
    "@zauso-ai/capstan-router": "0.3.1",
    "picocolors": "^1.1.1",
    "tsx": "^4.19.0",
    "zod": "^4.0.0"
  },
  "description": "CLI for Capstan — dev, build, verify, ops, add, mcp commands",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/barry3406/capstan.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "barry3406",
  "homepage": "https://github.com/barry3406/capstan",
  "keywords": [
    "capstan",
    "ai-agent",
    "full-stack",
    "framework",
    "mcp",
    "a2a",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  }
}
