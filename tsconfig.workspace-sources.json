      "@zauso-ai/capstan-cron": ["packages/cron/src/index.ts"],
      "@zauso-ai/capstan-db": ["packages/db/src/index.ts"],
      "@zauso-ai/capstan-dev": ["packages/dev/src/index.ts"],
      "@zauso-ai/capstan-dev/runtime": ["packages/dev/src/runtime.ts"],
      "@zauso-ai/capstan-ops": ["packages/ops/src/index.ts"],
      "@zauso-ai/capstan-react": ["packages/react/src/index.ts"],
      "@zauso-ai/capstan-react/client": ["packages/react/src/client/index.ts"],
