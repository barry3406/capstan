{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@zauso-ai/capstan-agent": ["packages/agent/src/index.ts"],
      "@zauso-ai/capstan-ai": ["packages/ai/src/index.ts"],
      "@zauso-ai/capstan-ai/kernel": ["packages/ai/src/harness/kernel/index.ts"],
