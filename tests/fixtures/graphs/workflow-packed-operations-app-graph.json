{
  "version": 1,
  "domain": {
    "key": "operations",
    "title": "Operations Workflow Hub",
    "description": "A packed operations app that composes tenant and workflow primitives."
  },
  "packs": [
    {
      "key": "tenant",
      "options": {
        "entityName": "Workspace",
        "entityPlural": "Workspaces"
      }
    },
    {
      "key": "workflow",
      "options": {
        "entityName": "Change Request",
        "entityPlural": "Change Requests",
        "resourceKey": "changeRequest",
        "artifactKey": "changeRequestReport"
      }
    }
  ],
  "resources": [
    {
      "key": "project",
      "title": "Project",
      "fields": {
        "name": {
          "type": "string",
          "required": true
        },
        "workspaceId": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "required": true
        }
      }
    }
  ],
  "capabilities": [
    {
      "key": "listProjects",
      "title": "List Projects",
      "description": "Browse projects scoped to one workspace.",
      "mode": "read",
      "resources": [
        "project"
      ],
      "policy": "tenantScoped"
    }
  ],
  "views": [
    {
      "key": "projectList",
      "title": "Projects",
      "kind": "list",
      "resource": "project",
      "capability": "listProjects"
    }
  ]
}
