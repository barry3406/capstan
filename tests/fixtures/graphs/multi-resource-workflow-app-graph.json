{
  "version": 1,
  "domain": {
    "key": "serviceDesk",
    "title": "Service Desk",
    "description": "A multi-resource graph used to verify that generated human workflows stay isolated per resource."
  },
  "resources": [
    {
      "key": "customer",
      "title": "Customer",
      "fields": {
        "name": {
          "type": "string",
          "required": true
        },
        "tier": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    {
      "key": "ticket",
      "title": "Ticket",
      "fields": {
        "title": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "required": true
        },
        "priority": {
          "type": "string"
        }
      }
    }
  ],
  "capabilities": [
    {
      "key": "createCustomer",
      "title": "Create Customer",
      "mode": "write",
      "resources": ["customer"],
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "tier": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    {
      "key": "createTicket",
      "title": "Create Ticket",
      "mode": "write",
      "resources": ["ticket"],
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "required": true
        },
        "priority": {
          "type": "string"
        }
      }
    },
    {
      "key": "listCustomers",
      "title": "List Customers",
      "mode": "read",
      "resources": ["customer"]
    },
    {
      "key": "listTickets",
      "title": "List Tickets",
      "mode": "read",
      "resources": ["ticket"]
    }
  ],
  "views": [
    {
      "key": "customerList",
      "title": "Customer Directory",
      "kind": "list",
      "resource": "customer",
      "capability": "listCustomers"
    },
    {
      "key": "ticketList",
      "title": "Ticket Queue",
      "kind": "list",
      "resource": "ticket",
      "capability": "listTickets"
    }
  ]
}
