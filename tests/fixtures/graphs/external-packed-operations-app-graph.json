{
  "version": 1,
  "domain": {
    "key": "operations",
    "title": "Operations External Pack Hub",
    "description": "A graph that relies on an external pack registry."
  },
  "packs": [
    {
      "key": "alerts"
    }
  ],
  "resources": [
    {
      "key": "project",
      "title": "Project",
      "fields": {
        "name": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "required": true
        }
      }
    }
  ],
  "capabilities": [
    {
      "key": "listProjects",
      "title": "List Projects",
      "mode": "read",
      "resources": [
        "project"
      ],
      "policy": "tenantScoped"
    }
  ],
  "views": [
    {
      "key": "projectList",
      "title": "Projects",
      "kind": "list",
      "resource": "project",
      "capability": "listProjects"
    }
  ]
}
