{
  "name": "capstan",
  "version": "0.3.0",
  "private": true,
  "description": "An AI Agent Native full-stack framework for building agent-operable software.",
  "packageManager": "npm@11.9.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node ./scripts/run-workspace-builds.mjs",
    "typecheck": "npm run typecheck --workspace @zauso-ai/capstan-cli",
    "dev": "tsx ./packages/cli/src/index.ts",
    "perf": "node ./scripts/run-perf.mjs",
    "perf:check": "node ./scripts/run-perf.mjs --check",
    "perf:list": "node ./scripts/run-perf.mjs --list",
    "test": "node ./scripts/run-bun-tests.mjs",
    "test:coverage": "CAPSTAN_COVERAGE=1 node ./scripts/run-bun-tests.mjs",
    "test:e2e": "playwright test",
    "test:meta": "node ./scripts/run-bun-tests.mjs tests/unit/meta-stability.test.ts",
    "test:new": "node ./scripts/run-bun-tests.mjs",
    "test:node": "vitest run tests/integration/page-auth-integration.test.ts tests/unit/nav-payload.test.ts tests/unit/hydration.test.ts tests/unit/client-entry.test.ts tests/unit/client-router.test.ts tests/unit/navigation-history.test.ts tests/unit/navigation-prefetch.test.ts tests/unit/navigation-router.test.ts tests/unit/navigation-url.test.ts tests/unit/page-runtime.test.ts tests/unit/react-auth-context.test.ts",
    "test:vitest": "vitest run",
    "test:llm": "node ./scripts/run-bun-tests.mjs tests/e2e/llm/smoke.test.ts tests/e2e/llm/long-run.test.ts tests/e2e/llm/scenario.test.ts",
    "test:llm:smoke": "node ./scripts/run-bun-tests.mjs tests/e2e/llm/smoke.test.ts",
    "test:llm:long": "node ./scripts/run-bun-tests.mjs tests/e2e/llm/long-run.test.ts tests/e2e/llm/scenario.test.ts",
    "test:watch": "vitest",
    "verify": "npm run dev -- verify"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "lightningcss": "^1.32.0",
    "zod": "^4.3.6"
  }
}
